{
  "rules": {
    "users": {
      ".read": true,
      "$uid": {
        ".write": "$uid === auth.uid || root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && (root.child('users').child(auth.uid).child('gameId').val() == 318843189 || root.child('config/admins').child(root.child('users').child(auth.uid).child('gameId').val() + '').exists())"
      }
    },
    "presence": {
      ".read": true,
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    },
    "stats": {
      "totalViews": {
        ".read": true,
        ".write": "newData.isNumber() && (!data.exists() || newData.val() == data.val() + 1)"
      }
    },
    "avatars": {
      ".read": true,
      "$gameId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('gameId').val() == $gameId || root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && (root.child('users').child(auth.uid).child('gameId').val() == 318843189 || root.child('config/admins').child(root.child('users').child(auth.uid).child('gameId').val() + '').exists()))"
      }
    },
    "fcmTokens": {
      "$token": {
        ".read": false,
        ".write": "auth != null"
      }
    },
    "sheets": { ".read": true, ".write": false },
    "config": {
      ".read": true,
      "rosterRegisteredOnly": {
        ".write": "auth != null && root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && root.child('users').child(auth.uid).child('gameId').val() == 318843189"
      },
      "admins": {
        ".write": "auth != null && root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && root.child('users').child(auth.uid).child('gameId').val() == 318843189"
      },
      "maintenanceMode": {
        ".write": "auth != null && root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && root.child('users').child(auth.uid).child('gameId').val() == 318843189"
      },
      "maintenanceEndTime": {
        ".write": "auth != null && root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && root.child('users').child(auth.uid).child('gameId').val() == 318843189"
      },
      "$otherConfig": {
        ".write": "auth != null && root.child('admin_sessions').child(auth.uid).child('unlockedUntil').val() > now && root.child('users').child(auth.uid).child('gameId').val() == 318843189"
      }
    },
    "system": { ".read": true, ".write": false },
    "bearTrapLog": { ".read": true, ".write": false },
    ".read": false,
    ".write": false
  }
}
